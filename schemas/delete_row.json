{
  "name": "delete_row",
  "description": "Permanently delete a row from a workspace. This action cannot be undone.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "slug": {
        "type": "string",
        "description": "The workspace slug"
      },
      "rowId": {
        "type": "string",
        "description": "The row ID to delete"
      }
    },
    "required": ["slug", "rowId"]
  }
}
