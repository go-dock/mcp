{
  "name": "@trydock/mcp",
  "version": "0.3.1",
  "description": "Local stdio MCP bridge to Dock — point any MCP-capable agent (Claude Desktop, Cursor, Windsurf, Zed, Cline, Continue) at your Dock workspaces.",
  "bin": {
    "dock-mcp": "src/bridge.js"
  },
  "type": "module",
  "files": [
    "src/**/*.js",
    "schemas/*.json",
    "configs/*.json",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://trydock.ai/docs/mcp",
  "bugs": "https://github.com/try-dock-ai/mcp/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/try-dock-ai/mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dock",
    "trydock",
    "claude",
    "cursor",
    "windsurf",
    "agents",
    "stdio"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
